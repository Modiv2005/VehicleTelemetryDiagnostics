<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.*?>

<VBox spacing="0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.telemetry.ui.controllers.VehicleSelectionController"
      stylesheets="@../style.css"
      styleClass="root">

    <children>
        <!-- Header (Marketplace Header) -->
        <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: #ffffff; -fx-padding: 20px 40px; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1px 0;">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="10" HBox.hgrow="ALWAYS">
                    <TextField promptText="Search vehicle model..." prefWidth="320" style="-fx-background-radius: 100px; -fx-background-color: #f1f5f9; -fx-padding: 10px 20px; -fx-text-fill: #1e293b;"/>
                    <Region HBox.hgrow="ALWAYS" />
                </HBox>
                
                <HBox alignment="CENTER_RIGHT" spacing="20">
                    <Label text="🌙" style="-fx-font-size: 18px; -fx-cursor: hand;"/>
                    <Label text="🔔" style="-fx-font-size: 18px; -fx-cursor: hand;"/>
                    <Circle radius="18" fill="#eff6ff" stroke="#3b82f6" strokeWidth="1" />
                    <Label text="V" style="-fx-font-weight: bold; -fx-text-fill: #3b82f6; -fx-font-size: 14px;"/>
                </HBox>
            </children>
        </HBox>

        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;">
            <content>
                <VBox spacing="40" style="-fx-padding: 40px 40px;">
                    <children>
                        <!-- Title Section -->
                        <HBox alignment="CENTER_LEFT">
                            <children>
                                <VBox spacing="5" HBox.hgrow="ALWAYS">
                                    <Label text="Electric Vehicle Models" styleClass="title-text" />
                                    <Label text="Explore popular EV models and their specifications" styleClass="subtitle-text" />
                                </VBox>
                                <Button text="Filters" styleClass="pill-filter" />
                            </children>
                        </HBox>

                        <!-- Category Filters -->
                        <HBox spacing="10">
                            <children>
                                <Button text="All Models" styleClass="pill-filter, pill-filter-active" />
                                <Button text="Sedans" styleClass="pill-filter" />
                                <Button text="SUVs" styleClass="pill-filter" />
                                <Button text="Performance" styleClass="pill-filter" />
                                <Button text="Eco-Mode" styleClass="pill-filter" />
                            </children>
                        </HBox>

                        <!-- MarketPlace Grid (Populated by Controller) -->
                        <TilePane fx:id="vehicleGrid" hgap="30" vgap="40" prefColumns="3" />
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </children>

</VBox>
